# Ensure client-side routes under /baseviewer/ return the SPA index
RewriteEngine On
RewriteBase /baseviewer/

# Do NOT rewrite requests for the assets folder (serve static files directly)
# With RewriteBase set, match against the local path under /baseviewer/
RewriteRule ^assets/ - [L]

# Serve existing files/directories normally
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise serve index.html (SPA fallback)
RewriteRule ^ index.html [L]
