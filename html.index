<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Velvedeer — Breeding & Showcase</title>

  <!-- Replace or remove these meta tags as you like -->
  <meta name="description" content="Velvedeer — a breeding simulator and gallery for procedurally-generated deer. Try the Breeding tool or explore the gallery." />
  <meta name="theme-color" content="#424a3e" />
  <link rel="icon" href="/assets/favicon.ico" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=La+Belle+Aurore&display=swap" rel="stylesheet">

  <style>
    :root{
      --accent: #2563eb;
      --bg: linear-gradient(180deg,#f7f7fb,#eef0f6);
      --muted: #71717a;
      --text: #0f172a;
      --header-bg: #424a3e;
      --header-contrast: #ffffff;
      --container-max: 1100px;
      --radius: 12px;
      --gap: 18px;
      --card-bg: #ffffff;
      --shadow: 0 8px 24px rgba(16,24,40,0.06);
      font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
    }

    html,body{height:100%}
    body{
      margin:0;
      min-height:100%;
      background:var(--bg);
      color:var(--text);
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      line-height:1.45;
    }

    /* Header */
    header.site-header{
      position:sticky;
      top:0;
      z-index:1000;
      background:var(--header-bg);
      color:var(--header-contrast);
      box-shadow: 0 1px 0 rgba(0,0,0,0.06);
      backdrop-filter: blur(4px);
    }
    .site-header .wrap{
      max-width: var(--container-max);
      margin: 0 auto;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:var(--gap);
      padding:12px 20px;
      box-sizing:border-box;
    }
    .brand{ display:flex; align-items:center; gap:12px; text-decoration:none; color:inherit; }
    .brand img.logo{ height:40px; width:auto; display:block; border-radius:6px; }
    .brand .title{ font-weight:700; font-size:18px; font-family: "La Belle Aurore", serif; color:#fff; }

    nav.main-nav{ display:flex; gap:8px; align-items:center; }
    nav.main-nav a{ color:var(--header-contrast); text-decoration:none; padding:8px 12px; border-radius:8px; font-weight:600; }
    nav.main-nav a:hover{ background: rgba(255,255,255,0.06); color:#fff; }

    /* Hamburger */
    button.hamburger{
      display:none;
      background:transparent; border:0; width:44px; height:44px; align-items:center; justify-content:center; cursor:pointer;
    }
    .hamburger .bar{ width:22px; height:2px; background:#fff; margin:3px 0; border-radius:2px; display:block; }

    /* Page content */
    main.container{
      max-width: var(--container-max);
      margin:28px auto;
      padding:24px;
      box-sizing:border-box;
    }

    .hero{
      display:grid;
      grid-template-columns: 1fr 420px;
      gap:24px;
      align-items:center;
      background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0.9));
      padding:28px;
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      border: 1px solid rgba(16,24,40,0.04);
    }
    .hero h1{ margin:0 0 12px 0; font-size:34px; letter-spacing:-0.02em; }
    .hero p.lead{ margin:0 0 18px 0; color:var(--muted); font-size:16px; }
    .hero .ctas{ display:flex; gap:12px; flex-wrap:wrap; }
    .btn{ display:inline-block; background:var(--accent); color:white; padding:10px 14px; border-radius:10px; text-decoration:none; font-weight:700; }
    .btn.ghost{ background:transparent; color:var(--text); border:1px solid #e5e7eb; }
    .hero-visual{
      width:100%;
      max-width:420px;
      height:320px;
      border-radius:10px;
      overflow:hidden;
      background:#fff center/cover no-repeat url('/assets/hero.jpg');
      border:1px solid rgba(16,24,40,0.04);
      box-shadow: 0 6px 20px rgba(16,24,40,0.06);
    }

    /* Features and gallery */
    .grid-3{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:16px;
      margin-top:20px;
    }
    .card{
      background:var(--card-bg);
      padding:14px;
      border-radius:10px;
      box-shadow: 0 6px 18px rgba(16,24,40,0.04);
      border:1px solid rgba(16,24,40,0.03);
    }
    .card h3{ margin:0 0 8px 0; font-size:18px; }
    .muted{ color:var(--muted); font-size:14px; }

    .gallery{
      display:flex;
      gap:12px;
      margin-top:18px;
      flex-wrap:wrap;
    }
    .gallery .thumb{
      width:160px; height:160px; border-radius:10px; background:#eee center/cover no-repeat; border:1px solid rgba(16,24,40,0.03);
    }

    footer.site-footer{
      margin-top:28px;
      padding:18px 24px;
      text-align:center;
      color:var(--muted);
    }

    /* Responsive */
    @media (max-width: 980px){
      .hero{ grid-template-columns: 1fr; }
      nav.main-nav{ display:none; }
      button.hamburger{ display:flex; }
      .grid-3{ grid-template-columns: 1fr; }
    }

    @media (max-width:480px){
      .hero h1{ font-size:26px; }
      .hero-visual{ height:220px; }
      .gallery .thumb{ width:120px; height:120px; }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="site-header" role="banner">
    <div class="wrap">
      <a class="brand" href="https://velvedeer.com/">
        <img class="logo" src="/assets/logo.png" alt="Velvedeer logo" onerror="this.style.display='none'"/>
        <span class="title">Velvedeer</span>
      </a>

      <nav class="main-nav" role="navigation" aria-label="Main menu">
        <a href="/">Home</a>
        <a href="/gallery/">Gallery</a>
        <a href="/breedingdemo/" class="nav-breeding">Breeding</a>
        <a href="/breedingdemo/" target="_blank" rel="noopener">Demo</a>
        <a href="/contact/">Contact</a>
      </nav>

      <button class="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>

    <!-- Mobile menu (cloned links) -->
    <div class="mobile-menu" style="display:none; background:var(--header-bg); border-top:1px solid rgba(255,255,255,0.03);">
      <div style="max-width:var(--container-max); margin:0 auto; padding:12px 20px;">
        <a href="/" style="display:block; padding:10px 0; color:var(--header-contrast); text-decoration:none;">Home</a>
        <a href="/gallery/" style="display:block; padding:10px 0; color:var(--header-contrast); text-decoration:none;">Gallery</a>
        <a href="/breedingdemo/" style="display:block; padding:10px 0; color:var(--header-contrast); text-decoration:none;">Breeding</a>
        <a href="/breedingdemo/" style="display:block; padding:10px 0; color:var(--header-contrast); text-decoration:none;">Demo</a>
        <a href="/contact/" style="display:block; padding:10px 0; color:var(--header-contrast); text-decoration:none;">Contact</a>
      </div>
    </div>
  </header>

  <!-- Main content -->
  <main class="container" role="main">
    <section class="hero" aria-labelledby="hero-heading">
      <div>
        <h1 id="hero-heading">Create. Breed. Collect.</h1>
        <p class="lead">Velvedeer is a procedural breeding simulator for unique deer. Design parents, breed offspring, and explore galleries of creations.</p>

        <div class="ctas">
          <a class="btn" href="/breedingdemo/">Open Breeding Tool</a>
          <a class="btn ghost" href="/breedingdemo/" target="_blank" rel="noopener">Try the Demo</a>
        </div>

        <div style="margin-top:18px;" class="muted">Tip: For the best experience open the Breeding tool in a new tab if you use client-side routing on the main site.</div>
      </div>

      <div class="hero-visual" role="img" aria-label="Velvedeer sample" ></div>
    </section>

    <section class="grid-3" aria-labelledby="features-heading">
      <div class="card">
        <h3 id="features-heading">Procedural Breeding</h3>
        <p class="muted">Randomize parents or set traits manually and breed multiple offspring to see trait inheritance and variation.</p>
      </div>
      <div class="card">
        <h3>Layered Avatars</h3>
        <p class="muted">Images are stacked as transparent layers so backgrounds show through. Swap backgrounds and preview live.</p>
      </div>
      <div class="card">
        <h3>Export & Share</h3>
        <p class="muted">Save and share your favorite offspring or add them to a gallery for the community to view.</p>
      </div>
    </section>

    <section aria-labelledby="gallery-heading" style="margin-top:20px;">
      <h2 id="gallery-heading">Recent creations</h2>
      <div class="gallery" aria-hidden="false">
        <!-- Replace these with actual thumbnails; use /assets/thumb1.jpg etc. -->
        <div class="thumb" style="background-image:url('/assets/thumb1.jpg')"></div>
        <div class="thumb" style="background-image:url('/assets/thumb2.jpg')"></div>
        <div class="thumb" style="background-image:url('/assets/thumb3.jpg')"></div>
        <div class="thumb" style="background-image:url('/assets/thumb4.jpg')"></div>
        <div class="thumb" style="background-image:url('/assets/thumb5.jpg')"></div>
      </div>
    </section>

    <footer class="site-footer" role="contentinfo">
      <div style="max-width:var(--container-max); margin:0 auto;">
        <div style="margin-bottom:8px;">© <span id="year"></span> Velvedeer — Built with care.</div>
        <div class="muted">Follow: <a href="https://twitter.com/" target="_blank" rel="noopener">Twitter</a> · <a href="https://instagram.com/" target="_blank" rel="noopener">Instagram</a></div>
      </div>
    </footer>
  </main>

  <script>
    // small UI helpers: mobile hamburger and year
    (function(){
      document.getElementById('year').textContent = new Date().getFullYear();

      const hamburger = document.querySelector('.hamburger');
      const mobileMenu = document.querySelector('.mobile-menu');
      const nav = document.querySelector('nav.main-nav');

      function toggleMenu(){
        const open = mobileMenu.style.display === 'block' ? false : true;
        mobileMenu.style.display = open ? 'block' : 'none';
        hamburger.setAttribute('aria-expanded', String(open));
      }
      if(hamburger){
        hamburger.addEventListener('click', toggleMenu);
      }

      // hide mobile menu on resize to desktop
      window.addEventListener('resize', function(){
        if(window.innerWidth > 980){
          mobileMenu.style.display = 'none';
          hamburger.setAttribute('aria-expanded', 'false');
        }
      });
    })();
  </script>
</body>
